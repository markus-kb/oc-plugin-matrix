{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "green": "#22c55e",
    "greenBright": "#86efac",
    "greenSoft": "#4ade80",
    "greenDim": "#166534",
    "greenFaint": "#14532d",
    "greenDark": "#052e16",
    "void": "#010402",
    "panel": "#031108",
    "panelAlt": "#052012"
  },
  "theme": {
    "primary": { "dark": "greenSoft", "light": "greenSoft" },
    "secondary": { "dark": "greenBright", "light": "greenBright" },
    "accent": { "dark": "greenBright", "light": "greenBright" },
    "error": { "dark": "greenBright", "light": "greenBright" },
    "warning": { "dark": "greenBright", "light": "greenBright" },
    "success": { "dark": "greenBright", "light": "greenBright" },
    "info": { "dark": "greenSoft", "light": "greenSoft" },
    "text": { "dark": "greenBright", "light": "greenBright" },
    "textMuted": { "dark": "greenDim", "light": "greenDim" },
    "background": { "dark": "void", "light": "void" },
    "backgroundPanel": { "dark": "panel", "light": "panel" },
    "backgroundElement": { "dark": "panelAlt", "light": "panelAlt" },
    "backgroundMenu": { "dark": "panelAlt", "light": "panelAlt" },
    "selectedListItemText": { "dark": "void", "light": "void" },
    "border": { "dark": "greenDim", "light": "greenDim" },
    "borderActive": { "dark": "greenSoft", "light": "greenSoft" },
    "borderSubtle": { "dark": "greenFaint", "light": "greenFaint" },
    "diffAdded": { "dark": "greenBright", "light": "greenBright" },
    "diffRemoved": { "dark": "greenDim", "light": "greenDim" },
    "diffContext": { "dark": "greenFaint", "light": "greenFaint" },
    "diffHunkHeader": { "dark": "greenSoft", "light": "greenSoft" },
    "diffHighlightAdded": { "dark": "greenBright", "light": "greenBright" },
    "diffHighlightRemoved": { "dark": "greenSoft", "light": "greenSoft" },
    "diffAddedBg": { "dark": "#062513", "light": "#062513" },
    "diffRemovedBg": { "dark": "#04140b", "light": "#04140b" },
    "diffContextBg": { "dark": "panel", "light": "panel" },
    "diffLineNumber": { "dark": "greenFaint", "light": "greenFaint" },
    "diffAddedLineNumberBg": { "dark": "#04140b", "light": "#04140b" },
    "diffRemovedLineNumberBg": { "dark": "#031008", "light": "#031008" },
    "markdownText": { "dark": "greenBright", "light": "greenBright" },
    "markdownHeading": { "dark": "greenBright", "light": "greenBright" },
    "markdownLink": { "dark": "greenBright", "light": "greenBright" },
    "markdownLinkText": { "dark": "greenBright", "light": "greenBright" },
    "markdownCode": { "dark": "greenBright", "light": "greenBright" },
    "markdownBlockQuote": { "dark": "greenDim", "light": "greenDim" },
    "markdownEmph": { "dark": "greenBright", "light": "greenBright" },
    "markdownStrong": { "dark": "greenBright", "light": "greenBright" },
    "markdownHorizontalRule": { "dark": "greenFaint", "light": "greenFaint" },
    "markdownListItem": { "dark": "greenSoft", "light": "greenSoft" },
    "markdownListEnumeration": { "dark": "greenDim", "light": "greenDim" },
    "markdownImage": { "dark": "greenBright", "light": "greenBright" },
    "markdownImageText": { "dark": "greenBright", "light": "greenBright" },
    "markdownCodeBlock": { "dark": "greenBright", "light": "greenBright" },
    "syntaxComment": { "dark": "greenDim", "light": "greenDim" },
    "syntaxKeyword": { "dark": "greenBright", "light": "greenBright" },
    "syntaxFunction": { "dark": "greenSoft", "light": "greenSoft" },
    "syntaxVariable": { "dark": "greenBright", "light": "greenBright" },
    "syntaxString": { "dark": "greenSoft", "light": "greenSoft" },
    "syntaxNumber": { "dark": "greenBright", "light": "greenBright" },
    "syntaxType": { "dark": "greenBright", "light": "greenBright" },
    "syntaxOperator": { "dark": "greenSoft", "light": "greenSoft" },
    "syntaxPunctuation": { "dark": "greenDim", "light": "greenDim" }
  }
}
